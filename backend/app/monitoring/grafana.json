{
  "dashboard": {
    "id": null,
    "title": "ARK Bot Metrics",
    "panels": [
      {
        "type": "graph",
        "title": "Winrate (%)",
        "targets": [{ "expr": "bot_winrate" }],
        "alert": {
          "conditions": [
            {
              "evaluator": { "type": "lt", "params": [0.4] },
              "operator": { "type": "and" },
              "query": { "params": ["A"] },
              "reducer": { "type": "avg" },
              "type": "query"
            }
          ],
          "notifications": ["telegram"]
        }
      },
      {
        "type": "graph",
        "title": "Total Profit",
        "targets": [{ "expr": "bot_total_profit" }]
      },
      {
        "type": "graph",
        "title": "Average Profit per Trade",
        "targets": [{ "expr": "bot_average_profit" }]
      },
      {
        "type": "graph",
        "title": "Max Drawdown",
        "targets": [{ "expr": "bot_max_drawdown" }],
        "alert": {
          "conditions": [
            {
              "evaluator": { "type": "gt", "params": [100] },
              "operator": { "type": "and" },
              "query": { "params": ["A"] },
              "reducer": { "type": "avg" },
              "type": "query"
            }
          ],
          "notifications": ["telegram"]
        }
      },
      {
        "type": "graph",
        "title": "Trades Count",
        "targets": [{ "expr": "bot_trades_count" }]
      },
      {
        "type": "graph",
        "title": "Profit Factor",
        "targets": [{ "expr": "bot_profit_factor" }]
      },
      {
        "type": "graph",
        "title": "Sharpe Ratio",
        "targets": [{ "expr": "bot_sharpe_ratio" }]
      },
      {
        "type": "graph",
        "title": "Sortino Ratio",
        "targets": [{ "expr": "bot_sortino_ratio" }]
      },
      {
        "type": "piechart",
        "title": "Win vs Loss Distribution",
        "targets": [
          { "expr": "sum(increase(bot_trades_count{result='win'}[1d]))" },
          { "expr": "sum(increase(bot_trades_count{result='loss'}[1d]))" }
        ]
      },
      {
        "type": "heatmap",
        "title": "Trading Activity by Hour",
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(bot_trades_count[1h])) by (hour))" }
        ]
      },
      {
        "type": "table",
        "title": "Recent Trades",
        "targets": [
          { "expr": "bot_recent_trades{symbol=~\"$symbol\",user_id=~\"$user_id\",strategy=~\"$strategy\"}" }
        ],
        "columns": ["trade_id", "symbol", "profit", "status", "user_id", "strategy"]
      },
      {
        "type": "graph",
        "title": "ML Training Accuracy",
        "targets": [{ "expr": "ml_training_accuracy" }]
      },
      {
        "type": "graph",
        "title": "ML Training Precision",
        "targets": [{ "expr": "ml_training_precision" }]
      },
      {
        "type": "graph",
        "title": "ML Training Recall",
        "targets": [{ "expr": "ml_training_recall" }]
      },
      {
        "type": "graph",
        "title": "ML Training Loss",
        "targets": [{ "expr": "ml_training_loss" }]
      },
      {
        "type": "graph",
        "title": "ML Training Loss per Epoch",
        "targets": [{ "expr": "ml_training_epoch_loss" }]
      },
      {
        "type": "gauge",
        "title": "ML Training Time (s)",
        "targets": [{ "expr": "ml_training_time_seconds" }]
      },
      {
        "type": "gauge",
        "title": "ML Training Learning Rate",
        "targets": [{ "expr": "ml_training_learning_rate" }]
      },
      {
        "type": "graph",
        "title": "ML CV Accuracy",
        "targets": [{ "expr": "ml_cv_accuracy" }]
      },
      {
        "type": "graph",
        "title": "ML CV Precision",
        "targets": [{ "expr": "ml_cv_precision" }]
      },
      {
        "type": "graph",
        "title": "ML CV Recall",
        "targets": [{ "expr": "ml_cv_recall" }]
      },
      {
        "type": "graph",
        "title": "ML CV Loss",
        "targets": [{ "expr": "ml_cv_loss" }]
      },
      {
        "type": "graph",
        "title": "ML Training Runs",
        "targets": [{ "expr": "ml_training_runs_total" }]
      },
      {
        "type": "graph",
        "title": "ML Predictions Total",
        "targets": [{ "expr": "ml_predictions_total" }]
      },
      {
        "type": "heatmap",
        "title": "ML Prediction Confidence Distribution",
        "targets": [{ "expr": "ml_prediction_confidence" }]
      },
      {
        "type": "graph",
        "title": "RabbitMQ Messages Published",
        "targets": [{ "expr": "rabbitmq_messages_published_total" }]
      },
      {
        "type": "graph",
        "title": "RabbitMQ Messages Consumed",
        "targets": [{ "expr": "rabbitmq_messages_consumed_total" }]
      },
      {
        "type": "graph",
        "title": "RabbitMQ Errors",
        "targets": [{ "expr": "rabbitmq_errors_total" }]
      },
      {
        "type": "graph",
        "title": "RabbitMQ Processing Time",
        "targets": [{ "expr": "rabbitmq_processing_time_seconds" }]
      },
      {
        "type": "graph",
        "title": "Redis Keys Total",
        "targets": [{ "expr": "redis_keys_total" }]
      },
      {
        "type": "graph",
        "title": "Redis Latency",
        "targets": [{ "expr": "redis_latency_seconds" }]
      },
      {
        "type": "graph",
        "title": "Redis Errors",
        "targets": [{ "expr": "redis_errors_total" }]
      },
      {
        "type": "graph",
        "title": "Indicator Tasks Total",
        "targets": [{ "expr": "indicators_tasks_total" }]
      },
      {
        "type": "graph",
        "title": "Indicator Task Duration",
        "targets": [{ "expr": "indicators_task_duration_seconds" }]
      },
      {
        "type": "graph",
        "title": "Indicator Queue Time",
        "targets": [{ "expr": "indicators_queue_time_seconds" }]
      },
      {
        "type": "graph",
        "title": "Indicator Task Errors",
        "targets": [{ "expr": "indicators_tasks_errors_total" }]
      },
      {
        "type": "graph",
        "title": "Bot Errors",
        "targets": [{ "expr": "bot_errors_total" }]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "symbol",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(bot_trades_count, symbol)"
        },
        {
          "name": "user_id",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(bot_trades_count, user_id)"
        },
        {
          "name": "strategy",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(bot_trades_count, strategy)"
        }
      ]
    }
  }
}
